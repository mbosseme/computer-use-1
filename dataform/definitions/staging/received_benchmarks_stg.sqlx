config {
  type: "table",
  name: "received_benchmarks_stg",
  description: "Staging copy of received benchmarks in local project to be processed by stored proc"
}

SELECT * FROM ${ref("received_benchmarks")}
QUALIFY ROW_NUMBER() OVER (
  PARTITION BY manufacturer_entity_code, manufacturer_catalog_number 
  ORDER BY abi_snapshot_date DESC
) = 1
